# Resend — https://resend.com/api-keys (verplicht voor verzenden)
RESEND_API_KEY=re_xxxxxxxx

# Optioneel: ontvanger (default staat in de API-route als je dit weglaat)
# CONTACT_TO_EMAIL=jouw@email.com

# Optioneel: afzender (default: The Seventies Band <onboarding@resend.dev>)
# RESEND_FROM_EMAIL=The Seventies Band <hello@jouwdomein.be>

# Optioneel: canonieke site-URL voor metadata
# NEXT_PUBLIC_SITE_URL=https://jouwdomein.be
