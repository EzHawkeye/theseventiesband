# Kopieer naar .env.local en vul waarden in (niet committen)
# Op Vercel: zelfde namen onder Project → Settings → Environment Variables

# Verplicht voor contactformulier (Resend)
RESEND_API_KEY=re_xxxxxxxx

# Optioneel — met onboarding@resend.dev vaak alleen naar je Resend-login-mail
# CONTACT_TO_EMAIL=jouw@email.com

# Optioneel
# RESEND_FROM_EMAIL=The Seventies Band <onboarding@resend.dev>

# Na deploy: productie-URL (ook in Vercel zetten)
# NEXT_PUBLIC_SITE_URL=https://jouw-app.vercel.app
